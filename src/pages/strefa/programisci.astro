---
import Strefa from '../../layouts/Strefa.astro';
---
<Strefa title="Programiści" active="programisci">
  <div class="strefa-head">
    <div>
      <p class="strefa-eyebrow">Strefa zamknięta</p>
      <h1>Programiści</h1>
      <p>Kokpit prowadzenia programistów ku autonomicznemu programowaniu intencyjnemu. Lista po firmach, etapy dojrzałości, umiejętności, notatki, spotkania, zadania, prompty i maile. Tabelę edytujesz z klawiatury.</p>
    </div>
    <div style="display:flex;gap:.4rem;flex-wrap:wrap;align-items:center">
      <button class="strefa-btn strefa-btn--ghost strefa-btn--sm" id="btn-history" title="Historia zmian i notatek (per miesiąc)">
        <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg>
        Historia
      </button>
      <button class="strefa-btn strefa-btn--ghost strefa-btn--sm" id="btn-schedule-meeting" title="Umów spotkania z wybranymi programistami (Google Calendar)">
        <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18M9 16l2 2 4-4"/></svg>
        Umów spotkanie
      </button>
      <button class="strefa-btn strefa-btn--ghost strefa-btn--sm" id="btn-import-legacy" title="Migracja danych ze starych tabel public.szron_*">Import z poprzedniej wersji</button>
      <button class="strefa-btn strefa-btn--ghost strefa-btn--sm" id="btn-import-file">Wgraj JSON</button>
      <button class="strefa-btn strefa-btn--ghost strefa-btn--sm" id="btn-export">Eksport JSON</button>
      <button class="strefa-btn strefa-btn--ghost strefa-btn--sm" id="btn-add-company">+ Firma</button>
      <button class="strefa-btn strefa-btn--accent" id="btn-add-dev">+ Programista</button>
    </div>
  </div>

  <div class="strefa-stats" id="stats" aria-live="polite"></div>

  <div class="strefa-toolbar">
    <div class="strefa-search">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3"/></svg>
      <input class="strefa-input" id="search" type="search" placeholder="Szukaj programisty, firmy, e-maila, projektu…" autocomplete="off" />
    </div>
  </div>

  <div id="companies" class="strefa-trainings"></div>
  <div id="empty" class="dgrid-empty" hidden>
    <p>Brak programistów. Dodaj firmę przyciskiem <strong>+ Firma</strong>, programistę przyciskiem <strong>+ Programista</strong> lub zaimportuj dane z poprzedniej wersji.</p>
  </div>

  <input type="file" id="file-input" accept="application/json,.json" hidden />
  <div id="modal-root"></div>
  <div class="strefa-toasts" id="toasts" aria-live="polite"></div>

  <script>
    import '../../lib/strefa-programisci.js';
  </script>
</Strefa>
