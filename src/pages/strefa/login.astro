---
import '../../styles/main.css';
import '../../styles/strefa.css';
---
<!doctype html>
<html lang="pl">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Logowanie — Strefa SZRON</title>
  <meta name="robots" content="noindex, nofollow" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Albert+Sans:wght@400;500;600&family=Space+Grotesk:wght@300..700&display=swap" rel="stylesheet" />
  <link rel="icon" type="image/svg+xml" href="/img/favicon.svg" />
</head>
<body class="strefa-body">
  <div class="strefa-login">
    <div class="strefa-login__box">
      <div class="strefa-login__brand">
        <img src="/img/logo-dark.svg" alt="SZRON" />
        <p>Strefa zamknięta</p>
      </div>
      <div class="strefa-login__card">
        <h1>Zaloguj się</h1>

        <button type="button" class="strefa-google" id="btn-google">
          <svg viewBox="0 0 24 24" aria-hidden="true"><path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.27-4.74 3.27-8.1Z"/><path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84A11 11 0 0 0 12 23Z"/><path fill="#FBBC05" d="M5.84 14.1a6.6 6.6 0 0 1 0-4.2V7.06H2.18a11 11 0 0 0 0 9.88l3.66-2.84Z"/><path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1A11 11 0 0 0 2.18 7.06l3.66 2.84C6.71 7.3 9.14 5.38 12 5.38Z"/></svg>
          Zaloguj przez Google
        </button>

        <div class="strefa-divider">albo loginem</div>

        <div id="login-msg" hidden></div>

        <form id="login-form">
          <div class="strefa-field">
            <label for="email">E-mail</label>
            <input class="strefa-input" type="email" id="email" name="email" autocomplete="username" required />
          </div>
          <div class="strefa-field">
            <label for="password">Hasło</label>
            <input class="strefa-input" type="password" id="password" name="password" autocomplete="current-password" required />
          </div>
          <button type="submit" class="strefa-btn strefa-btn--accent" id="btn-login" style="width:100%;padding:.65rem">Zaloguj się</button>
        </form>
        <a href="/strefa/reset" style="display:block;text-align:center;margin-top:var(--space-md);font-size:var(--text-caption);color:var(--color-text-inv-3)">Nie pamiętasz hasła?</a>
      </div>
      <a class="strefa-login__back" href="/">← Powrót na szron.tech</a>
    </div>
  </div>

  <script>
    import { getSessionUser, isAllowed, signInPassword, signInGoogle } from '../../lib/supabase.js';

    const params = new URLSearchParams(window.location.search);
    const next = params.get('next') || '/strefa';
    const safeNext = next.startsWith('/strefa') ? next : '/strefa';

    const msg = document.getElementById('login-msg');
    const showErr = (t) => { msg.hidden = false; msg.className = 'strefa-msg strefa-msg--err'; msg.textContent = t; };

    // już zalogowany i uprawniony → od razu do strefy
    (async () => {
      const u = await getSessionUser();
      if (u && isAllowed(u.email)) window.location.replace(safeNext);
    })();

    document.getElementById('btn-google').addEventListener('click', async (e) => {
      e.currentTarget.disabled = true;
      const { error } = await signInGoogle(safeNext);
      if (error) { showErr(error); e.currentTarget.disabled = false; }
    });

    document.getElementById('login-form').addEventListener('submit', async (e) => {
      e.preventDefault();
      const btn = document.getElementById('btn-login');
      btn.disabled = true; msg.hidden = true;
      const email = document.getElementById('email').value;
      const password = document.getElementById('password').value;
      const { error } = await signInPassword(email, password);
      if (error) { showErr(error); btn.disabled = false; return; }
      window.location.replace(safeNext);
    });
  </script>
</body>
</html>
