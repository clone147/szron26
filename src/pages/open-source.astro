---
import Interior from '../layouts/Interior.astro';

// Narzędzia open source SZRON — treść wg starej strony (OpenSource.tsx)
const tools = [
  {
    name: 'szron-db2-mcp',
    badges: [{ label: 'MCP Server' }, { label: 'NEW', kind: 'new' }],
    desc: 'Serwer MCP, który podłącza agenta AI do bazy IBM DB2. Pytasz o dane zwykłym językiem — agent sam ułoży zapytanie, zaktualizuje rekord, w razie potrzeby stworzy tabelę. Bez otwierania konsoli DB2.',
    features: [
      'Pełen odczyt i zapis: SELECT, INSERT, UPDATE, DELETE',
      'Operacje DDL — CREATE, ALTER, DROP TABLE z constraintami',
      'Ochrona przed SQL injection — wymóg WHERE, walidacja zapytań',
    ],
    install: 'git clone https://github.com/clone147/szron-db2-mcp',
    github: 'https://github.com/clone147/szron-db2-mcp',
  },
  {
    name: 'skill-imagegen',
    badges: [{ label: 'Claude Code Skill' }, { label: 'NEW', kind: 'new' }],
    desc: 'Generowanie obrazów AI z wbudowanym AI art directorem. Napisz prosty prompt — skill zamieni go w kinematograficzny opis i wygeneruje profesjonalny obraz. Wymienny model przez OpenRouter pod spodem.',
    features: [
      'Auto-enhancement: prosty prompt → profesjonalny opis',
      'Edycja z referencjami — do 14 obrazów wejściowych',
      'Rozdzielczości 1K / 2K / 4K, dowolne proporcje',
    ],
    install: 'claude install-skill https://github.com/clone147/skill-imagegen',
    github: 'https://github.com/clone147/skill-imagegen',
  },
  {
    name: 'humanizer-pl',
    badges: [{ label: 'Claude Code Skill' }],
    desc: 'Skill do Claude Code, który wykrywa i usuwa ślady AI z polskich tekstów. 37 wzorców specyficznych dla języka polskiego — imiesłowy, anglicyzmy, strona bierna, formułkowe zdania.',
    features: [
      '37 wzorców AI specyficznych dla polskiego',
      'Specyfika polskiego: imiesłowy, anglicyzmy, strona bierna',
      'Instalacja jedną linijką — gotowy do użycia w minutę',
    ],
    install: 'claude install-skill https://github.com/clone147/humanizer-pl',
    github: 'https://github.com/clone147/humanizer-pl',
  },
  {
    name: 'subtitle-downloader',
    badges: [{ label: 'Claude Code Skill' }, { label: 'NEW', kind: 'new' }],
    desc: 'Mówisz jaki film, jaki język — dostajesz napisy. Skill automatycznie wykrywa film z nazwy pliku i pobiera napisy z wielu źródeł.',
    features: [
      '3 źródła: subliminal, napiprojekt, OpenSubtitles',
      'Napiprojekt — najlepsza baza polskich napisów (hash MD5)',
      'Automatyczna detekcja filmu z nazwy pliku',
    ],
    install: 'claude install-skill https://github.com/clone147/subtitle-downloader',
    github: 'https://github.com/clone147/subtitle-downloader',
  },
];
---
<Interior
  title="Open source — narzędzia AI od SZRON | szron-db2-mcp, skille Claude Code"
  description="Narzędzia open source, które tworzymy przy wdrożeniach AI — serwer MCP dla IBM DB2 i skille do Claude Code. Udostępniamy za darmo na licencji MIT."
  eyebrow="Open source"
  heading="Budujemy na otwarto."
  lead="Narzędzia, które tworzymy przy wdrożeniach AI — udostępniamy za darmo. Używaj, kontrybuuj, rozwijaj."
>
  <!-- proof -->
  <section class="sect" style="padding-bottom:0">
    <div class="container">
      <div class="proof-strip rv">
        <div><strong>4 narzędzia</strong><span>serwer MCP + skille Claude Code</span></div>
        <div><strong>37 wzorców</strong><span>w humanizerze polskiego tekstu</span></div>
        <div><strong>MIT License</strong><span>za darmo, bez haczyków</span></div>
      </div>
    </div>
  </section>

  <!-- narzędzia -->
  <section class="sect" aria-labelledby="narzedzia">
    <div class="container">
      <div class="sect-head">
        <p class="eyebrow rv" data-scramble>01 / Narzędzia · Sprawdzone w boju</p>
        <h2 class="sect-title sect-title--s ws" id="narzedzia">Każde powstało przy realnym projekcie wdrożeniowym.</h2>
      </div>
      <div class="grid-cards">
        {tools.map((t, i) => (
          <article class="card-tile tool-card rv" style={`--rv-d:${(i * 0.08).toFixed(2)}s`}>
            <div class="badges">
              {t.badges.map((b) => <span class={`badge${b.kind === 'new' ? ' badge--new' : ''}`}>{b.label}</span>)}
            </div>
            <h3>{t.name}</h3>
            <p>{t.desc}</p>
            <ul class="features">
              {t.features.map((f) => <li>{f}</li>)}
            </ul>
            <div class="install">
              <code>{t.install}</code>
              <button type="button" class="install__btn" data-copy={t.install} aria-label={`Kopiuj komendę instalacji ${t.name}`}>Kopiuj</button>
            </div>
            <p class="tool-foot"><a href={t.github} target="_blank" rel="noopener noreferrer">Zobacz na GitHub →</a></p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- dlaczego open source -->
  <section class="sect sect--dark" aria-labelledby="dlaczego">
    <div class="container">
      <div class="sect-head">
        <p class="eyebrow rv" data-scramble>02 / Dlaczego · Po co to robimy</p>
        <h2 class="sect-title ws" id="dlaczego">Dlaczego open source?</h2>
      </div>
      <div class="grid-cards">
        <article class="card-tile rv">
          <p class="eyebrow">Powstaje przy pracy</p>
          <h3>Sprawdzone w boju, nie w teorii.</h3>
          <p>Każde narzędzie powstało przy realnym projekcie wdrożeniowym. Nie teoria — rozwiązanie problemu, na który sami trafiliśmy.</p>
        </article>
        <article class="card-tile rv" style="--rv-d:.1s">
          <p class="eyebrow">Społeczność ponad marketing</p>
          <h3>Feedback wart więcej niż kampania.</h3>
          <p>Opinia developerów, którzy realnie używają narzędzia, jest cenniejsza niż reklamy. Budujemy razem z tymi, którzy z tego korzystają.</p>
        </article>
        <article class="card-tile rv" style="--rv-d:.2s">
          <p class="eyebrow">Standard budujemy razem</p>
          <h3>Polski AI tooling jest młody.</h3>
          <p>Im więcej osób kontrybuuje, tym lepsze narzędzia powstają. Oddajemy społeczności to, co tworzymy przy projektach.</p>
        </article>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="sect sect--dark cta-band" aria-labelledby="cta" style="padding-top:0">
    <div class="container">
      <p class="eyebrow rv" data-scramble>Masz pomysł?</p>
      <h2 class="ws" id="cta" style="margin-top:var(--space-lg)">Masz pomysł na narzędzie?</h2>
      <p class="rv">Budujemy narzędzia, które pomagają polskim zespołom pracować z AI. Jeśli masz pomysł albo chcesz kontrybuować — napisz.</p>
      <div class="contact__cta rv">
        <a class="btn btn--accent" href="/kontakt">Napisz do nas
          <span class="btn__arr" aria-hidden="true">
            <svg viewBox="0 0 16 16" fill="none"><path d="M2 8h11M9 3.5 13.5 8 9 12.5" stroke="currentColor" stroke-width="1.8"/></svg>
            <svg viewBox="0 0 16 16" fill="none"><path d="M2 8h11M9 3.5 13.5 8 9 12.5" stroke="currentColor" stroke-width="1.8"/></svg>
          </span>
        </a>
        <a class="btn btn--ghost" href="https://github.com/clone147" target="_blank" rel="noopener noreferrer">Zobacz GitHub</a>
      </div>
    </div>
  </section>

  <script is:inline>
    document.querySelectorAll('.install__btn').forEach((btn) => {
      btn.addEventListener('click', async () => {
        try {
          await navigator.clipboard.writeText(btn.getAttribute('data-copy'));
          const old = btn.textContent;
          btn.textContent = 'Skopiowano';
          btn.classList.add('is-done');
          setTimeout(() => { btn.textContent = old; btn.classList.remove('is-done'); }, 2000);
        } catch (e) {}
      });
    });
  </script>
</Interior>
