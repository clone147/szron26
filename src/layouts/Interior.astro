---
import Base from './Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { pageSchema } from '../data/page-schema.mjs';

// Layout stron wewnętrznych: ciemny baner nagłówka → biała „kartka" z sekcjami → stopka.
// Ten sam język wizualny co homepage, bez sticky-hero.
const {
  title,
  description,
  ogDescription,
  ogImage,
  eyebrow,          // krótki tag nad tytułem (np. "03 / Metoda")
  heading,          // H1 w banerze
  lead,             // akapit pod H1
  headingSmall = false, // mniejszy H1 dla długich tytułów
  heroImage,            // opcjonalna grafika bohatera (ścieżka /img/sub/...)
  heroAlt = '',
} = Astro.props;

// per-stronowe JSON-LD (breadcrumb + typ strony)
const site = Astro.site ?? new URL('https://szron.tech');
const canonical = new URL(Astro.url.pathname, site).href;
const image = heroImage ? new URL(heroImage, site).href : null;
const schema = pageSchema(Astro.url.pathname, { title, description, heading, image, canonical, site });
---
<Base title={title} description={description} ogDescription={ogDescription} ogImage={ogImage} schema={schema}>
  <Nav />
  <header class={`page-hero${heroImage ? ' page-hero--media' : ''}`}>
    <div class="container">
      <div class="page-hero__inner">
        <div class="page-hero__text">
          {eyebrow && <p class="eyebrow rv" data-scramble>{eyebrow}</p>}
          <h1 class={`page-hero__title ws${headingSmall ? ' page-hero__title--s' : ''}`}>{heading}</h1>
          {lead && <p class="page-hero__lead rv" set:html={lead} />}
        </div>
        {heroImage && (
          <figure class="page-hero__media rv">
            <img src={heroImage} alt={heroAlt} loading="eager" decoding="async"
                 onload="this.parentElement.classList.add('has-img')" onerror="this.closest('.page-hero').classList.remove('page-hero--media'); this.parentElement.remove()" />
          </figure>
        )}
      </div>
    </div>
  </header>
  <div class="page-body page-body--interior">
    <slot />
    <Footer />
  </div>
</Base>
